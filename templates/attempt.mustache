<div id="codeeditorWrapper">
    <h3 id='taskDescription' class="mb-4"> {{#str}} taskheader, codescore {{/str}} </h3>
    <p class="mb-4">{{task}}</p>
    <textarea id="codeEditor"></textarea>
    <textarea placeholder="You can write notes for teachers here" name="" id="codeNotes" class="mt-3 form-control" cols="30" rows="3"></textarea>

    <form action="{{backUrl}}" method="post" id="saveAndExitForm">
        <input type="hidden" id="code" name="code" value="{{code}}">
        <input type="hidden" id="notes" name="notes" value="{{notes}}">
        <input type="hidden" id="cmid" name="cmid" value="{{cmid}}">
        <input type="hidden" id="sesskey" name="sesskey" value="{{sesskey}}">
        <input type="submit" value="Save and exit" id="submitattemptbutton" class="btn btn-primary mt-4">
    </form>
</div>
{{#js}}
    require(['mod_codescore/codeEditor'], (module) => module.init());
{{/js}}