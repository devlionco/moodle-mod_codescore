<h3> {{#str}} taskoverview, codescore {{/str}} </h3>
<ul>
    <li> {{#str}} reportlang, codescore {{/str}} {{lang}}</li>
    <li> {{#str}} taskreport, codescore {{/str}} <br/> {{task}}</li>
    <li> {{#str}} maxgradesyntax, codescore {{/str}} {{syntaxgrade}}</li>
    <li> {{#str}} maxrightoutput, codescore {{/str}} {{outputgrade}}</li>
    <li> {{#str}} maxproblemsolution, codescore {{/str}} {{problemsolutiongrade}}</li>
    <li> {{#str}} maxcovering, codescore {{/str}} {{allcasesgrade}}</li>
</ul>
    <h3>{{name}} {{#str}} reportname, codescore {{/str}} </h3>
<ul>
    <li>{{#str}} reportgrade, codescore {{/str}} {{grade}}</li>
    <li>{{#str}} aigradereport, codescore {{/str}} {{aigrade}}</li>
    <li>{{#str}} syntaxreport, codescore {{/str}} {{syntaxgrading}}</li>
    <li>{{#str}} outputreport, codescore {{/str}} {{outputgrading}}</li>
    <li>{{#str}} problemreport, codescore {{/str}} {{problemsolutiongrading}}</li>
    <li>{{#str}} casesreport, codescore {{/str}} {{allcasesgrading}}</li>
    <li>{{#str}} notesreport, codescore {{/str}} {{studentnotes}}</li>
</ul>
<input type="hidden" value="{{code}}" id="codeValue">
<input type="hidden" value="{{correctedcode}}" id="correctedCodeValue">
<h2 class="mb-4">{{#str}} codediffreport, codescore {{/str}} </h2>
<div class="d-flex justify-content-around codeDiffTitle">
    <h3>{{#str}} studentcodereport, codescore {{/str}}</h3>
    <h3>{{#str}} correctcodereport, codescore {{/str}}</h3>
</div>
<div id="mergeViewWrapper"></div>
{{#isteacher}}
    <form action="{{backUrl}}" class="mt-3" method="post" id="saveAndExitForm">
        <input type="number" min="0" max="100" step="1" class="form-control" id="grade" name="grade" value="{{grade}}">
        <input type="hidden" id="id" name="id" value="{{id}}">
        <input type="hidden" id="cmid" name="cmid" value="{{cmid}}">
        <input type="hidden" id="userid" name="userid" value="{{userid}}">
        <input type="submit" value="{{#str}} reportgradebtn, codescore {{/str}}" id="submitattemptbutton" class="btn btn-primary ml-2">
    </form>
{{/isteacher}}
{{#js}}
    require(['mod_codescore/report'], (module) => module.init());
{{/js}}